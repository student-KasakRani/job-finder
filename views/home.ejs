<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>job-finder</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">

</head>
<body>
    <nav class="bg-white shadow-md p-4 flex justify-between">
      <h1 class="text-2xl font-bold text-blue-600">job finder</h1>
      <div class="flex space-x-4">
      <a href="#" class="mr-4 text-gray-700 hover:text-blue-600">Home</a>
      <a href="#" class="text-gray-700 hover:text-blue-600">Login</a>

    
<form action="/search" method="GET" class="flex">
        <input type="text" name="query" placeholder="Search Jobs..." class="border p-2 rounded-l">
        <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-r">Search</button>
    </form>
  </div>

    </nav>
    <section class="text-center mt-20">
      <h1 class="text-4xl font-bold text-gray-800">find your dream job</h1>
      <p class="mt-4 text-gray-600">Serach and apply jobs easily</p>
      <div class="mt-6">
        <input type="text" placeholder="Search jobs..." class="border p-2 w-1/3 rounded">
        <button class="bg-blue-600 text-white p-2 rounded">Search</button>
      </div>
    </section>

    <section class="mt-10 p-6 bg-white shadow-md rounded w-1/2 mx-auto">
      <h3 class="text-2xl font-bold mb-4">Add a new job</h3>
      <form action="/add" method="POST" class="space-y-4">
        <input type ="text" name="title" placeholder=" job title" class="w-full border p-2 rounded">
        <input type="text" name="company" placeholder="company name" class="w-full border p-2 rounded">
        <input type="text" name="location" placeholder="Location" class="w-full border p-2 rounded">
        <button type="Submit" class="bg-blue-600 text-white px-4 py-2 rounded">Add job</button>
      </form>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 p-6">
  <% jobs.forEach((job, index) => { %>
    <div class="bg-white shadow-md rounded p-4">
      <h3 class="text-xl font-semibold text-gray-800"><%= job.title %></h3>
      <p class="text-gray-600"><%= job.location %> - <%= job.company %></p>
      
      <a href="/apply/<%= job._id %>" class="mt-4 inline-block bg-blue-600 text-white px-4 py-2 rounded">Apply now</a> 
      
      <form action="/delete" method="POST">
        <input type="hidden" name="id" value="<%= job._id %>">
        <button class="mt-2 bg-red-600 text-white px-4 py-1 rounded">Delete</button>
      </form>

    </div>
  <% }) %>
</div>

</body>
</html>